<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="0dp">

    <!-- Chat Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#E94560"
        android:gravity="center_vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bubble Chat"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingLeft="8dp"/>

        <Button
            android:id="@+id/btn_close_chat"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="X"
            android:textColor="#FFFFFF"
            android:background="#CC2244"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"/>
    </LinearLayout>

    <!-- Chat Log (scrollable) -->
    <ScrollView
        android:id="@+id/scroll_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#16213E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_chat_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F3460"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:hintTextColor="#888888"
            android:textColor="#FFFFFF"
            android:background="#1A1A2E"
            android:padding="10dp"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:layout_marginRight="8dp"/>

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:textColor="#FFFFFF"
            android:background="#E94560"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"/>
    </LinearLayout>

</LinearLayout>
          
